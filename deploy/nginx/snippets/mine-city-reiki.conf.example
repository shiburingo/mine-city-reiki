location = /mine-city-reiki { return 301 /mine-city-reiki/; }
location /mine-city-reiki/ {
  alias /var/www/mine-city-reiki/;
  try_files $uri $uri/ /mine-city-reiki/index.html;
}

location /mine-city-reiki-api/ {
  proxy_http_version 1.1;
  proxy_set_header Host $host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;
  rewrite ^/mine-city-reiki-api/?(.*)$ /$1 break;
  proxy_pass http://127.0.0.1:8795;
}
