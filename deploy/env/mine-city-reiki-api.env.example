DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=mine_city_reiki
DB_PASSWORD=CHANGE_ME
DB_NAME=mine_city_reiki
DB_CHARSET=utf8mb4
DB_AUTO_INIT=1

MINE_CITY_REIKI_API_PORT=8795
AUTH_VERIFY_URL=http://127.0.0.1:8787/api/auth/verify
AUTH_APP_SLUG=mine-city-reiki
MINE_CITY_REIKI_AUTH_BYPASS=0

# Daily cumulative thesaurus growth. Wikimedia requests are serial and use maxlag.
REIKI_DAILY_DICTIONARY_MEDIAWIKI=1
REIKI_DAILY_DICTIONARY_WIKIPEDIA_LIMIT=5000
REIKI_DAILY_DICTIONARY_WIKTIONARY_LIMIT=2000
REIKI_DAILY_DICTIONARY_WIKIDATA=1
REIKI_DAILY_DICTIONARY_WIKIDATA_TERMS=25
REIKI_DICTIONARY_USER_AGENT=mine-city-reiki-thesaurus-bot/0.1 (https://github.com/shiburingo/mine-city-reiki)
# Generate legacy JSON only while the dictionary is small enough to load safely.
REIKI_SYNONYM_JSON_COMPAT_MAX_TERMS=100000

# Optional: Meilisearch-backed fast search. Keep disabled until the service is installed and indexed.
MEILI_ENABLED=0
MEILI_URL=http://127.0.0.1:7700
MEILI_MASTER_KEY=CHANGE_ME_AT_LEAST_16_BYTES
MEILI_INDEX=mine_city_reiki_articles
# 会議録は例規・法令と分離した専用インデックスを使います。
MEILI_MINUTES_INDEX=mine_city_meeting_minutes
